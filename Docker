FROM ubuntu:22.4

#install required packages
RUN apt-get update
    apt-get install -y openjdk-21-jdk curl && \
    rm -rf /var/lib/apt/lists/*

#set Tomcat version
ENV TOMCAT_VERSION=9.0.119
ENV TOMCAT_HOME=/opt/Tomcat

#download and extact Tomcat
RUN curl -fsSL https://dlcdn.apache.org/tomcat/tomcat-9/v{TOMCAT_VERSION}/bin/apache-tomcat-{TOMCAT_VERSION}.tar.gz | tar -xz -C /opt/ && \ mv /opt/apache-tomcat-${TOMCAT_VERSION} ${TOMCAT_HOME}
#set envornment veriable (your practive veriable)
ENV department=dev

#expose tomcat port
EXPOSE 8080

#set working directory
WORKDIR ${TOMCAT_HOME}/bin

#start tomcat
CMD [ "./catalina.sh", "run"]